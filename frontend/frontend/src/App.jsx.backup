import { useCallback, useState } from 'react'
import Home from './Home.jsx'
import HomePage from './HomePage.jsx'
import LoginForm from './LoginForm.jsx'
import RegisterForm from './RegisterForm.jsx'
import Navigation from './Navigation.jsx'
import appLogo from '../images/WhatsApp Image 2026-03-31 at 23.38.56.jpeg'

const DEFAULT_API =
  import.meta.env.VITE_API_URL?.replace(/\/$/, '') || 'http://127.0.0.1:5001'

function apiUrl(path) {
  const p = path.startsWith('/') ? path : `/${path}`
  return `${DEFAULT_API}${p}`
}

const SRI_LANKA_VIDEO =
  'https://videos.pexels.com/video-files/5538630/5538630-hd_1920_1080_25fps.mp4'
const SRI_LANKA_POSTER =
  'https://images.unsplash.com/photo-1586861635167-e5223aadc9fe?q=80&w=1920&auto=format&fit=crop'

export default function App() {
  const [showLandingOnly, setShowLandingOnly] = useState(true)
  const [token, setToken] = useState(() => localStorage.getItem('smart_tour_token') || '')
  const [userName, setUserName] = useState(() => localStorage.getItem('smart_tour_name') || '')
  const [activePage, setActivePage] = useState('landing')
  const [showLogin, setShowLogin] = useState(false)
  const [showRegister, setShowRegister] = useState(false)

  const handleLogin = (newToken, newName) => {
    setToken(newToken)
    setUserName(newName)
    setShowLogin(false)
    setActivePage('dashboard')
  }

  const handleRegister = () => {
    setShowRegister(false)
    setShowLogin(true)
  }

  const handleLogout = () => {
    setToken('')
    setUserName('')
    setActivePage('landing')
    setShowLogin(false)
    setShowRegister(false)
  }

  const showLoginModal = () => {
    setShowLogin(true)
    setShowRegister(false)
  }

  const showRegisterModal = () => {
    setShowRegister(true)
    setShowLogin(false)
  }

  const [vehicleType, setVehicleType] = useState('Car')
  const [locationCount, setLocationCount] = useState(3)
  const [loading, setLoading] = useState(false)
  const [error, setError] = useState('')
  const [info, setInfo] = useState('')
  const [estimate, setEstimate] = useState(null)

  const loggedIn = Boolean(token)

  const persistSession = useCallback((t, name) => {
    setToken(t)
    setUserName(name || '')
    if (t) localStorage.setItem('smart_tour_token', t)
    else localStorage.removeItem('smart_tour_token')
    if (name) localStorage.setItem('smart_tour_name', name)
    else localStorage.removeItem('smart_tour_name')
  }, [])

  const handleStartTour = useCallback(() => {
    setActivePage('plan-trip')
  }, [])

  const handleBackToHome = useCallback(() => {
    setActivePage('landing')
  }, [])

  const handleOpenPlanTrip = useCallback(() => {
    setActivePage('plan-trip')
  }, [])

  const inputClass = useCallback((id) => {
    document.getElementById(id)?.scrollIntoView({ behavior: 'smooth', block: 'start' })
  }, [])

  const openLoginPage = useCallback(() => {
    setShowLandingOnly(false)
    window.scrollTo({ top: 0, behavior: 'smooth' })
  }, [])

  return (
    <div className="relative min-h-screen overflow-hidden bg-gradient-to-br from-sky-100 via-orange-50 to-sky-50">
      {showLandingOnly ? (
        <div className="absolute inset-0">
          <video
            className="h-full w-full object-cover"
            autoPlay
            loop
            muted
            playsInline
            poster={SRI_LANKA_POSTER}
          >
            <source src={SRI_LANKA_VIDEO} type="video/mp4" />
          </video>
          <div className="absolute inset-0 bg-gradient-to-b from-slate-950/35 via-slate-950/55 to-slate-950/80" />
          <div className="absolute inset-0 bg-[radial-gradient(circle_at_18%_20%,rgba(56,189,248,0.32),transparent_36%),radial-gradient(circle_at_82%_14%,rgba(249,115,22,0.28),transparent_34%)]" />
        </div>
      ) : (
        <div className="absolute inset-0 bg-[radial-gradient(circle_at_18%_20%,rgba(56,189,248,0.2),transparent_36%),radial-gradient(circle_at_82%_14%,rgba(249,115,22,0.18),transparent_34%)]" />
      )}

      <Navigation 
        showLandingOnly={showLandingOnly}
        setShowLandingOnly={setShowLandingOnly}
        token={token}
        userName={userName}
        onLogout={handleLogout}
      />
                >
                  Destinations
                </button>
                <button
                  type="button"
                  onClick={() => scrollToId('sl-features')}
                  className="font-medium text-white/80 transition-colors hover:text-white"
                >
                  Services
                </button>
                <button
                  type="button"
                  onClick={() => scrollToId('sl-testimonials')}
                  className="font-medium text-white/80 transition-colors hover:text-white"
                >
                  Client Feedback
                </button>
                <button
