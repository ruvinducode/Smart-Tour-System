                  {
                    title: 'Kandy Temple of the Tooth',
                    subtitle: 'Sacred Buddhist Relic Site',
                    image: 'https://images.unsplash.com/photo-1518509562904-e7ef99cdcc86?q=80&w=1920&auto=format&fit=crop',
