              </div>
            </section>

              {/* Beautiful Sri Lanka Gallery with Scroll Effects */}
            <section id="sl-gallery" className="mx-auto max-w-7xl py-16">
              <div className="mb-12 text-center">
                <h3 className="font-['Space_Grotesk'] text-4xl font-bold text-white md:text-5xl">
